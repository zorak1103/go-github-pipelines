version: '3'

vars:
  MODULE: "{{MODULE}}"
  BINARY: "{{BINARY}}"
  VERSION:
    sh: git describe --tags --always --dirty 2>/dev/null || echo "dev"
  LDFLAGS: "-s -w -X {{MODULE}}/internal/version.Version={{.VERSION}}"
  COVERAGE_THRESHOLD: "80"
  GOFLAGS: ""
  RACE: ""

tasks:
  # ============================================================================
  # DEVELOPMENT
  # ============================================================================
  default:
    desc: Build the project
    cmds:
      - task: build

  build:
    desc: Compile the binary
    env:
      CGO_ENABLED: "0"
    cmds:
      - go build -ldflags "{{.LDFLAGS}}" -o {{.BINARY}}{{exeExt}} ./cmd/{{.BINARY}}/

  run:
    desc: Run the application
    cmds:
      - go run ./cmd/{{.BINARY}}/ {{.CLI_ARGS}}

  clean:
    desc: Remove build artifacts
    cmds:
      - rm -f {{.BINARY}}{{exeExt}} coverage.out coverage-report.txt vulncheck_output.json

  # ============================================================================
  # TESTING
  # ============================================================================
  test:
    desc: Run tests (set RACE=-race for race detection)
    env:
      CGO_ENABLED: "{{if .RACE}}1{{else}}0{{end}}"
    cmds:
      - go test {{.RACE}} {{.GOFLAGS}} ./...

  test:coverage:
    desc: Run tests with per-file coverage enforcement (80% gate)
    env:
      CGO_ENABLED: "1"
    cmds:
      - go test -race -coverprofile=coverage.out -covermode=atomic ./...
      - ./scripts/check-coverage.sh coverage.out {{.COVERAGE_THRESHOLD}}

  test:watch:
    desc: Run tests in watch mode (requires gotestsum)
    env:
      CGO_ENABLED: "1"
    cmds:
      - gotestsum --watch ./...

  # ============================================================================
  # CODE QUALITY
  # ============================================================================
  lint:
    desc: Run golangci-lint (CI installs it; locally run `task lint:install` first)
    cmds:
      - golangci-lint run --timeout=5m ./...

  lint:install:
    desc: Install golangci-lint locally (tracked by Renovate)
    cmds:
      # renovate: datasource=go depName=github.com/golangci/golangci-lint/v2
      - go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@{{GOLANGCI_VERSION}}

  fmt:
    desc: Format Go code
    cmds:
      - gofmt -w .

  fmt:check:
    desc: Check Go formatting (non-destructive)
    cmds:
      - |
        unformatted=$(gofmt -l .)
        if [ -n "$unformatted" ]; then
          echo "Unformatted files:"; echo "$unformatted"; exit 1
        fi

  vet:
    desc: Run go vet
    cmds:
      - go vet ./...

  # ============================================================================
  # SECURITY
  # ============================================================================
  vulncheck:
    desc: Run govulncheck (CI installs it; locally run `task vulncheck:install` first)
    cmds:
      - govulncheck ./...

  vulncheck:install:
    desc: Install govulncheck locally (tracked by Renovate)
    cmds:
      # renovate: datasource=go depName=golang.org/x/vuln
      - go install golang.org/x/vuln/cmd/govulncheck@{{GOVULNCHECK_VERSION}}

  # ============================================================================
  # DEPENDENCY MANAGEMENT
  # ============================================================================
  tidy:
    desc: Tidy go modules
    cmds:
      - go mod tidy

  deps:download:
    desc: Download all dependencies
    cmds:
      - go mod download
