# GitHub Actions Release Workflow for {{PROJECT}}
# Triggered on version tags (v*)
# Uses GoReleaser for multi-platform builds, Docker images, and changelog

name: Release

on:
  push:
    tags:
      - 'v*'

permissions:
  contents: write

jobs:
  # ============================================================================
  # VERIFY - Re-run lint+test before publishing (gates the release job)
  # ============================================================================
  verify:
    name: Verify (lint + test)
    runs-on: ubuntu-latest
    env:
      CGO_ENABLED: "1"
    steps:
      - name: Checkout code
        uses: actions/checkout@v6

      - name: Setup Go
        uses: actions/setup-go@v6
        with:
          go-version-file: go.mod
          cache: true

      # [FRONTEND-EMBED: insert setup-node step here]

      - name: Setup Task
        uses: arduino/setup-task@v2  # SHA-pin
        with:
          version: 3.x
          repo-token: ${{ secrets.GITHUB_TOKEN }}

      - name: Download dependencies
        run: go mod download

      # [FRONTEND-EMBED: insert build:frontend step here]

      - name: Install golangci-lint
        # renovate: datasource=go depName=github.com/golangci/golangci-lint/v2
        run: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@{{GOLANGCI_VERSION}}

      - name: Run lint
        run: task lint

      - name: Run tests
        run: task test:coverage

  # ============================================================================
  # RELEASE - Build and publish via GoReleaser (gated on verify)
  # ============================================================================
  release:
    name: Release
    needs: verify
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v6
        with:
          fetch-depth: 0  # Full history required for changelog generation

      - name: Setup Go
        uses: actions/setup-go@v6
        with:
          go-version-file: go.mod
          cache: true

      # [FRONTEND-EMBED: insert setup-node step here]

      - name: Setup Task
        uses: arduino/setup-task@v2  # SHA-pin
        with:
          version: 3.x
          repo-token: ${{ secrets.GITHUB_TOKEN }}

      - name: Download dependencies
        run: go mod download

      # [FRONTEND-EMBED: insert build:frontend step here]

      - name: Set up QEMU
        uses: docker/setup-qemu-action@v4  # SHA-pin

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v4  # SHA-pin

      - name: Log in to Docker Hub
        uses: docker/login-action@v4  # SHA-pin
        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_PASSWORD }}

      - name: Run GoReleaser
        uses: goreleaser/goreleaser-action@v7  # SHA-pin
        with:
          distribution: goreleaser
          # renovate: datasource=github-releases depName=goreleaser/goreleaser
          version: {{GORELEASER_VERSION}}
          args: release --clean
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
