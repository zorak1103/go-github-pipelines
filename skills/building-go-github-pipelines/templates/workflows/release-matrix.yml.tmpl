# generated by go-github-pipelines v{{SKILL_VERSION}}
# GitHub Actions Release Workflow for {{PROJECT}} — Manual Matrix
# Binary-only release (no Docker). 5 platform targets + GitHub Release.
# Use this instead of release-goreleaser when no Docker/nfpm packages are needed.
#
# Job graph:
#   verify ─► build (matrix ×5, each uploads one artifact) ─► publish (single, creates release)
# The fan-in avoids the parallel action-gh-release race: only publish calls the Releases API.

name: Release

on:
  push:
    tags:
      - 'v*'

jobs:
  # ============================================================================
  # CI gate — all CI jobs must pass before release runs
  # ============================================================================
  verify:
    name: Verify (lint + test)
    runs-on: ubuntu-latest
    env:
      CGO_ENABLED: "1"
    steps:
      - name: Checkout code
        uses: actions/checkout@v6

      - name: Setup Go
        uses: actions/setup-go@v6
        with:
          go-version-file: go.mod
          cache: true

      - name: Setup Task
        uses: arduino/setup-task@v2  # SHA-pin
        with:
          version: 3.x
          repo-token: ${{ secrets.GITHUB_TOKEN }}

      - name: Download dependencies
        run: go mod download

      - name: Install golangci-lint
        # renovate: datasource=go depName=github.com/golangci/golangci-lint/v2
        run: go install github.com/golangci/golangci-lint/v2/cmd/golangci-lint@{{GOLANGCI_VERSION}}

      - name: Run lint
        run: task lint

      - name: Run tests
        run: task test:coverage

  # ============================================================================
  # BUILD — Cross-compile for all target platforms, upload each binary as artifact
  # ============================================================================
  build:
    name: Build (${{ matrix.suffix }})
    needs: verify
    runs-on: ubuntu-latest
    strategy:
      matrix:
        include:
          - goos: linux
            goarch: amd64
            suffix: linux-amd64
          - goos: linux
            goarch: arm64
            suffix: linux-arm64
          - goos: windows
            goarch: amd64
            suffix: windows-amd64
            ext: .exe
          - goos: darwin
            goarch: amd64
            suffix: darwin-amd64
          - goos: darwin
            goarch: arm64
            suffix: darwin-arm64
    steps:
      - name: Checkout code
        uses: actions/checkout@v6

      - name: Setup Go
        uses: actions/setup-go@v6
        with:
          go-version-file: go.mod
          cache: true

      # [FRONTEND-EMBED: insert setup-node step here]

      - name: Setup Task
        uses: arduino/setup-task@v2  # SHA-pin
        with:
          version: 3.x
          repo-token: ${{ secrets.GITHUB_TOKEN }}

      - name: Download dependencies
        run: go mod download

      # [FRONTEND-EMBED: insert build:frontend step here]

      - name: Build binary
        env:
          GOOS: ${{ matrix.goos }}
          GOARCH: ${{ matrix.goarch }}
          CGO_ENABLED: "0"
          REF_NAME: ${{ github.ref_name }}
          SUFFIX: ${{ matrix.suffix }}
          EXT: ${{ matrix.ext || '' }}
        run: |
          go build \
            -ldflags="-s -w -X {{MODULE}}/internal/version.Version=${REF_NAME}" \
            -o "{{BINARY}}-${SUFFIX}${EXT}" \
            ./cmd/{{BINARY}}/

      - name: Upload binary as artifact
        uses: actions/upload-artifact@v7
        with:
          name: {{BINARY}}-${{ matrix.suffix }}
          path: {{BINARY}}-${{ matrix.suffix }}${{ matrix.ext || '' }}
          retention-days: 1

  # ============================================================================
  # PUBLISH — Download all binaries, create a single GitHub Release
  # ============================================================================
  publish:
    name: Publish GitHub Release
    needs: build
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - name: Download all binaries
        uses: actions/download-artifact@v8
        with:
          path: dist/
          merge-multiple: true

      - name: Create GitHub Release
        uses: softprops/action-gh-release@v3  # SHA-pin
        with:
          files: dist/*
          generate_release_notes: true
